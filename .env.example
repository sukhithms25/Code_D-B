# ==================================
# SERVER CONFIGURATION
# ==================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ==================================
# DATABASE - REQUIRED
# ==================================
# MongoDB connection string (local or Atlas)
# Example: mongodb://localhost:27017/code_db
# Example: mongodb+srv://user:pass@cluster.mongodb.net/code_db
MONGODB_URI=mongodb://localhost:27017/code_db

# ==================================
# JWT SECRETS - REQUIRED
# ==================================
# Generate strong secrets: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-minimum-32-chars
JWT_REFRESH_EXPIRE=7d

# ==================================
# OPENAI - REQUIRED
# ==================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000

# ==================================
# YOUTUBE API - REQUIRED
# ==================================
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================
# EMAIL CONFIGURATION - REQUIRED
# ==================================
# Use Gmail App Password or SMTP credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-not-regular-password

# ==================================
# CORS CONFIGURATION - REQUIRED
# ==================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================================
# GITHUB OAUTH (Optional for MVP)
# ==================================
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/integrations/github/callback

# ==================================
# RATE LIMITING
# ==================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================================
# FILE UPLOAD
# ==================================
MAX_FILE_SIZE=5242880
ALLOWED_RESUME_TYPES=application/pdf

# ==================================
# N8N WEBHOOK (Optional)
# ==================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/

# ==================================
# LOGGING
# ==================================
LOG_LEVEL=debug
